#!/bin/sh

EXPECTED_VID="cafe"
EXPECTED_PID="4005"
EXPECTED_SERIAL="R4-0001"

find_r4_port() {
    for device in /dev/ttyACM*; do
        [ -e "$device" ] || continue

        properties="$(udevadm info --query=property --name="$device" 2>/dev/null)"

        vid="$(printf '%s\n' "$properties" |
            sed -n 's/^ID_VENDOR_ID=//p')"

        pid="$(printf '%s\n' "$properties" |
            sed -n 's/^ID_MODEL_ID=//p')"

        serial="$(printf '%s\n' "$properties" |
            sed -n 's/^ID_SERIAL_SHORT=//p')"

        interface="$(printf '%s\n' "$properties" |
            sed -n 's/^ID_USB_INTERFACE_NUM=//p')"

        if [ "$vid" = "$EXPECTED_VID" ] &&
           [ "$pid" = "$EXPECTED_PID" ] &&
           [ "$serial" = "$EXPECTED_SERIAL" ] &&
           [ "$interface" = "00" ]; then
            printf '%s\n' "$device"
            return 0
        fi
    done

    return 1
}

if [ "$#" -eq 0 ]; then
    command="PING"
else
    command="$*"
fi

port="$(find_r4_port)" || {
    echo "R4 embedded controller not found" >&2
    exit 1
}

stty -F "$port" 115200 raw -echo || exit 1

exec 3<>"$port" || {
    echo "Unable to open $port" >&2
    exit 1
}

printf '%s\r\n' "$command" >&3

response="$(timeout 2 head -n 1 <&3)"
read_status=$?

if [ "$read_status" -eq 0 ] && [ -n "$response" ]; then
    response="$(printf '%s' "$response" | tr -d '\r')"
    printf '%s\n' "$response"
else
    echo "R4 embedded controller response timeout" >&2
    exec 3>&-
    exit 1
fi

exec 3>&-
