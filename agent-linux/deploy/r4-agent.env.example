# R4 Linux Agent configuration.
# Copy this file to /etc/r4-agent/r4-agent.env and edit values for your host.

# Hub base URL. Use your real Hub address in production.
R4_HUB_URL=http://127.0.0.1:8080

# Human-readable agent name shown in Hub.
R4_AGENT_NAME=r4-linux-agent

# Persistent local data directory. The agent stores agent-id here.
R4_AGENT_DATA_DIR=/var/lib/r4-agent

# Durations accept ISO-8601 values such as PT10S or integer milliseconds.
R4_HEARTBEAT_INTERVAL=PT10S
R4_COMMAND_POLL_INTERVAL=PT5S
R4_HTTP_CONNECT_TIMEOUT=PT5S
R4_HTTP_REQUEST_TIMEOUT=PT10S
