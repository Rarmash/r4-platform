# Copy to .env before running compose.production.yml.
# Values here are examples only. Do not commit real production secrets.

# Hub image. Pin R4_HUB_VERSION to an immutable release or SHA tag in production.
R4_HUB_IMAGE=rarmash/r4-hub
R4_HUB_VERSION=0.1.0

# Published Hub port.
R4_HUB_BIND_ADDRESS=127.0.0.1
R4_HUB_PORT=8080

# JVM options for the Hub container.
R4_HUB_JAVA_OPTS=-XX:MaxRAMPercentage=75.0

# PostgreSQL settings.
R4_DB_NAME=r4
R4_DB_USERNAME=r4
R4_DB_PASSWORD=change-me-local-example
R4_DB_POOL_SIZE=5
