#!/bin/sh

ECCTL="/userdata/system/r4/r4-ecctl"
LED_STATE="/userdata/system/r4/r4-led-state"

PID_FILE="/tmp/r4-controller-service.pid"
STATE_FILE="/tmp/r4-controller-service.state"
LOG_FILE="/userdata/system/r4/r4-controller.log"

EXPECTED_VERSION="R4_CONTROLLER_FW 0.4.0"
CHECK_INTERVAL=2

log_message() {
    printf '%s %s\n' \
        "$(date '+%Y-%m-%d %H:%M:%S')" \
        "$*" \
        >> "$LOG_FILE"
}

rotate_log() {
    [ -f "$LOG_FILE" ] || return 0

    log_size="$(wc -c < "$LOG_FILE" 2>/dev/null)"

    if [ -n "$log_size" ] &&
       [ "$log_size" -gt 131072 ]; then
        mv "$LOG_FILE" "${LOG_FILE}.1"
    fi
}

is_running() {
    [ -f "$PID_FILE" ] || return 1

    service_pid="$(cat "$PID_FILE" 2>/dev/null)"
    [ -n "$service_pid" ] || return 1

    kill -0 "$service_pid" 2>/dev/null
}

set_state() {
    printf '%s\n' "$1" > "$STATE_FILE"
}

run_watchdog() {
    printf '%s\n' "$$" > "$PID_FILE"

    trap '
        rm -f "$PID_FILE"
        set_state "stopped"
        exit 0
    ' 1 2 15

    previous_state=""

    log_message "Watchdog started with PID $$"

    while true; do
        ping_response="$("$ECCTL" PING 2>/dev/null)"

        if [ "$ping_response" = "PONG" ]; then
            version_response="$("$ECCTL" VERSION 2>/dev/null)"

            if [ "$version_response" = "$EXPECTED_VERSION" ]; then
                current_state="online"
            else
                current_state="version-mismatch"
            fi
        else
            version_response=""
            current_state="offline"
        fi

        set_state "$current_state"

        if [ "$current_state" != "$previous_state" ]; then
            case "$current_state" in
                online)
                    log_message \
                        "Controller connected: $version_response"

                    # Green: controller and firmware are ready.
                    if [ -x "$LED_STATE" ]; then
   			 "$LED_STATE" apply >/dev/null 2>&1
		    else
    			"$ECCTL" LED 0 16 0 >/dev/null 2>&1
		    fi
                    ;;

                version-mismatch)
                    log_message \
                        "Firmware mismatch: expected '$EXPECTED_VERSION', got '$version_response'"

                    # Amber: connected, but firmware version is unexpected.
                    "$ECCTL" LED 16 8 0 >/dev/null 2>&1
                    ;;

                offline)
                    log_message "Controller disconnected"
                    ;;
            esac
        fi

        previous_state="$current_state"
        sleep "$CHECK_INTERVAL"
    done
}

start_service() {
    rotate_log

    if is_running; then
        echo "R4 Controller watchdog is already running"
        return 0
    fi

    rm -f "$PID_FILE"
    set_state "starting"

    "$0" run >/dev/null 2>&1 &
    new_pid=$!

    sleep 1

    if kill -0 "$new_pid" 2>/dev/null; then
        echo "R4 Controller watchdog started"
        return 0
    fi

    echo "Unable to start R4 Controller watchdog" >&2
    return 1
}

stop_service() {
    if is_running; then
        service_pid="$(cat "$PID_FILE")"

        kill "$service_pid" 2>/dev/null

        attempt=0

        while kill -0 "$service_pid" 2>/dev/null; do
            attempt=$((attempt + 1))

            if [ "$attempt" -ge 5 ]; then
                kill -9 "$service_pid" 2>/dev/null
                break
            fi

            sleep 1
        done
    fi

    rm -f "$PID_FILE"
    set_state "stopped"

    "$ECCTL" LED OFF >/dev/null 2>&1 || true

    log_message "Watchdog stopped"
    echo "R4 Controller watchdog stopped"
}

show_status() {
    if is_running; then
        service_pid="$(cat "$PID_FILE")"
        echo "Service: running (PID $service_pid)"
    else
        echo "Service: stopped"
    fi

    if [ -f "$STATE_FILE" ]; then
        echo "State: $(cat "$STATE_FILE")"
    else
        echo "State: unknown"
    fi

    controller_status="$("$ECCTL" STATUS 2>/dev/null)"

    if [ -n "$controller_status" ]; then
        echo "Controller: $controller_status"
    else
        echo "Controller: unavailable"
    fi
}

case "$1" in
    start)
        start_service
        ;;

    stop)
        stop_service
        ;;

    restart)
        stop_service
        sleep 1
        start_service
        ;;

    status)
        show_status
        ;;

    run)
        run_watchdog
        ;;

    *)
        echo "Usage: $0 {start|stop|restart|status}" >&2
        exit 1
        ;;
esac
